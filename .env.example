# Copy to .env and fill in. Values below match docker-compose.yml defaults.

# Async SQLAlchemy DSN (asyncpg driver) for the ParadeDB Postgres service.
DATABASE_URL=postgresql+asyncpg://minddrill:minddrill@localhost:5432/minddrill

# Redis (used by Celery ingestion in a later slice).
REDIS_URL=redis://localhost:6379/0

# Secret for signing JWTs. Generate a long random value for real use.
JWT_SECRET=change-me

# Gemini free-tier API key (primary inference provider). Leave blank for slice 0.
GEMINI_API_KEY=

# OpenRouter fallback: used when Gemini 429s or fails before the first token.
# Key: https://openrouter.ai/keys. The :free suffix keeps the model on the no-cost tier.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Embedding dimension. Fixed by the embedding model; changing it means re-embedding.
EMBED_DIM=768

RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2
RERANK_TOP_N=5
RERANK_ENABLED=true

# Grounding gate: decline instead of answering when the top reranked cross-encoder
# score is below this floor. Skipped when RERANK_ENABLED=false.
GROUNDING_MIN_SCORE=0.0
