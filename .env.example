# Copy to .env and fill in. Values below match docker-compose.yml defaults.

# Async SQLAlchemy DSN (asyncpg driver) for the ParadeDB Postgres service.
DATABASE_URL=postgresql+asyncpg://minddrill:minddrill@localhost:5432/minddrill

# Redis (used by Celery ingestion in a later slice).
REDIS_URL=redis://localhost:6379/0

# Secret for signing JWTs. Generate a long random value for real use.
JWT_SECRET=change-me

# Gemini free-tier API key (primary inference provider). Leave blank for slice 0.
GEMINI_API_KEY=

# OpenRouter fallback: used when Gemini 429s or fails before the first token.
# Key: https://openrouter.ai/keys. The :free suffix keeps the model on the no-cost tier.
OPENROUTER_API_KEY=
# OpenRouter periodically retires free-tier model slugs; re-check
# https://openrouter.ai/models?max_price=0 if this starts 404ing.
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# Embedding dimension. Fixed by the embedding model; changing it means re-embedding.
EMBED_DIM=768

RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2
RERANK_TOP_N=5
RERANK_ENABLED=true

# Grounding gate: decline instead of answering when the top reranked cross-encoder
# score is below this floor. Skipped when RERANK_ENABLED=false.
GROUNDING_MIN_SCORE=0.0

# Short-term chat memory: recent turns are trimmed to this many tokens before
# building the /chat prompt. Conversation history only — separate from RAG.
MEMORY_TOKEN_BUDGET=2000

# Ceiling on the agent's model calls per /chat request. On the limit the loop
# ends gracefully and returns the best answer so far instead of looping tools.
AGENT_MAX_STEPS=6

# Langfuse API Keys
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# Offline eval only (eval/run_eval.py): seconds to wait between each question's
# generate call, to stay under the free-tier per-minute rate limit.
EVAL_REQUEST_DELAY_SECONDS=6.5
